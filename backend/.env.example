# --- App ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3001

# --- MongoDB ---
# Local dev (via docker-compose):
MONGODB_URI=mongodb://mongo:27017/vehicle_survey
# Production (Atlas):
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/vehicle_survey?retryWrites=true&w=majority

# --- JWT ---
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- AWS S3 ---
AWS_REGION=ap-south-1
AWS_S3_BUCKET=vehicle-surveys-dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_SIGNED_URL_EXPIRES_SECONDS=900

# --- Auth bootstrap (used by `npm run seed:admin`) ---
BOOTSTRAP_ADMIN_EMPLOYEE_ID=admin
BOOTSTRAP_ADMIN_NAME=System Administrator
BOOTSTRAP_ADMIN_MOBILE=0000000000
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# --- Rate limiting ---
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10

# --- Uploads ---
MAX_PHOTO_BYTES=5242880
MAX_PHOTOS_PER_REQUEST=20
