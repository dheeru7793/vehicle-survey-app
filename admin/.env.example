# Backend base URL the Next.js server will hit (server-side; not exposed to browser)
API_BASE_URL=http://localhost:4000/api/v1

# How long the cookie is valid (seconds). Match backend JWT_EXPIRES_IN.
SESSION_COOKIE_MAX_AGE=604800

# Browser-side. Required for the Survey Detail map.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
